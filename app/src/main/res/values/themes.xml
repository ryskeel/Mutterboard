<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Brand fallback colors apply when the device has no dynamic color to
         override them (older Android, or dynamic color unavailable/off). On
         Pixel/Samsung etc. DynamicColors.wrapContextIfAvailable still overlays
         the wallpaper accent, so the keyboard keeps following the system theme
         where one exists. These keep the IME buttons + equalizer on-brand
         (monochrome chrome, matching the settings screen) instead of falling
         back to Material's baseline purple. -->
    <style name="Theme.Mutterboard" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_kb_primary</item>
        <item name="colorOnPrimary">@color/brand_kb_on_primary</item>
        <item name="colorSecondaryContainer">@color/brand_kb_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/brand_kb_on_secondary_container</item>
    </style>

</resources>
